# Trading Room API (Rust) — environment configuration
API_HOST=0.0.0.0
API_PORT=8080

# Postgres (shared with the Laravel backend during cutover)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tradingroom

# Redis (cache, queues)
REDIS_URL=redis://127.0.0.1:6379

# Logging (overrides the default level; e.g. info, debug, tradingroom_api=debug)
RUST_LOG=info

# Comma-separated allowed CORS origins (empty = none in production)
CORS_ORIGINS=http://localhost:5173
